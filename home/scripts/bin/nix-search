#!/usr/bin/env bash
# Search nixpkgs and install packages interactively
set -euo pipefail

if ! command -v fzf &>/dev/null; then
  echo "fzf is required: nix profile install nixpkgs#fzf" >&2
  exit 1
fi

pkgs=$(nix search nixpkgs ^ --json 2>/dev/null \
  | jq -r 'to_entries[] | (.key | split(".") | .[2:] | join("."))' \
  | sort \
  | fzf --multi \
      --preview 'nix eval nixpkgs#{}.meta.description --raw 2>/dev/null || echo "No description"' \
      --preview-window=down:3:wrap \
      --bind 'alt-p:toggle-preview' \
      --color 'pointer:green,marker:green')

if [[ -n "$pkgs" ]]; then
  echo "$pkgs" | tr '\n' ' ' | xargs -r nix profile install nixpkgs#
fi
